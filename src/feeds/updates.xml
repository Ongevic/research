---
layout: null
permalink: /feeds/updates.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0">
  <channel>
    <title>{{ site.name | xml_escape }} Updates</title>
    <link>{{ '/news/' | absolute_url }}</link>
    <description>{{ site.description | xml_escape }}</description>
    <language>en</language>
    {% assign posts = site.news | sort: "date" | reverse %}
    {% for post in posts limit:20 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | absolute_url }}</link>
      <guid>{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <description>{{ post.excerpt | strip_html | strip_newlines | replace: "  ", " " | xml_escape }}</description>
    </item>
    {% endfor %}
  </channel>
</rss>
